[node name="Dialog" parent="CanvasLayer" unique_id=794257179 instance=ExtResource("2_2hcnx")]
full_text = Array[String](["0Добрый вечер, это вы занимаетесь услугами по призыву и общению с духами?", "1Здравствуйте, мэм, да.", "0Мне очень нужна ваша помощь...", "1Что случилось мэм?", "0Понимаете, моя дочь... её больше нет.", "1Приношу свои соболезнования вашей утрате.", "0Моя дочь... её жестоко убили.", "1Вы знаете убийцу?", "0Да... это был очень дорогой мне человек, он являлся отцом моей дочери.", "0Я не знаю где сейчас он и что с ним, но моя дочь...", "0...Она приходит каждую ночь ко мне и плачет.", "0Постоянно молит папу прекратить её пытать и просит её не убивать.", "0Эти крики и слезы! Я начинаю сходить с ума! Упокойте её душу...", "1Имя и фамилия?", "0Алиса... Ретрайвел.", "1Дата рождения?", "025 апреля 19XX года.", "1Оплата после ритуала.", "1Иначе вас настигнет кара.", "0Я вас поняла. Пожалуйста, избавьте моё от мучений..", "1Досвидания."])
autostart = false
function_name = "start_phone_dialog_over"

